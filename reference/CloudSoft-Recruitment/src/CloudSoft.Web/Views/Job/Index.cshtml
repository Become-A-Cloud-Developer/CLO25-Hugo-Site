@model IEnumerable<Job>
@{
    ViewData["Title"] = "Job Listings";
}

<h2>Job Listings</h2>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<p>
    <a asp-action="Create" class="btn btn-primary">
        <i class="fas fa-plus"></i> Post New Job
    </a>
</p>

@if (!Model.Any())
{
    <div class="alert alert-info">No jobs posted yet.</div>
}
else
{
    <div class="row">
        @foreach (var job in Model)
        {
            <div class="col-md-6 col-lg-4 mb-4">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title">@job.Title</h5>
                        <p class="card-text text-muted">
                            <i class="fas fa-map-marker-alt"></i> @job.Location
                        </p>
                        <p class="card-text">@(job.Description.Length > 150 ? job.Description[..150] + "..." : job.Description)</p>
                    </div>
                    <div class="card-footer bg-transparent">
                        <small class="text-muted">
                            <i class="fas fa-calendar"></i> Deadline: @job.Deadline.ToString("yyyy-MM-dd")
                        </small>
                        <a asp-action="Details" asp-route-id="@job.Id" class="btn btn-sm btn-outline-primary float-end">
                            View Details
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
}
